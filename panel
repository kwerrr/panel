@router.message(AdminPayState.price)
async def admin_price_input(msg: Message, state: FSMContext):
    if not is_admin(msg.from_user.id): return
    try:
        sale = float(msg.text.strip().replace(",", "."))
        if sale <= 0:
            raise ValueError
    except ValueError:
        await msg.answer(f'{E["warn"]} Введи положительное число. Пример: <b>10.5</b>')
        return

    d      = await state.get_data()
    pid    = d["pid"]
    p      = await db_get_payout(pid)
    pct    = p["commission_pct"]
    profit = round(sale * (1 - pct / 100), 6)

    await db_set_payout_price(pid, sale, profit)

    w    = await db_get_worker(p["worker_id"])
    wnam = w["full_name"] if w else f"ID:{p['worker_id']}"
    wun  = f" @{w['username']}" if w and w["username"] else ""

    await msg.answer(
        f'{E["chart"]} <b>Расчёт выплаты #{pid}</b>\n\n'
        f'👤 Воркер: {wnam}{wun}\n'
        f'🔖 Код: <code>{p["deal_code"]}</code>\n\n'
        f'{E["dollar"]} Продано за:         <b>{sale:.4f} TON</b>\n'
        f'{E["warn"]} Комиссия ({pct}%):  <b>{sale * pct / 100:.4f} TON</b>\n'
        f'{E["coin"]} Выплата воркеру ({100-pct}%): <b>{profit:.4f} TON</b>\n\n'
        f'{E["card"]} Кошелёк: <code>{p["wallet"]}</code>',
        reply_markup=kb_admin_confirm(pid)
    )
    await state.clear()

