async def make_group_invite(bot: Bot, uid: int, name: str) -> str:
    """
    Создаёт уникальную invite-ссылку для трафера через Bot API.
    Требует: бот является администратором INVITE_CHAT_ID
             с правом 'Пригласительные ссылки'.
    При ошибке — возвращает общий GROUP_LINK.
    """
    try:
        result = await bot.create_chat_invite_link(
            chat_id=INVITE_CHAT_ID,
            name=f"Трафер {name} [id{uid}]",
            creates_join_request=False,   # False = сразу вступает, True = заявка
        )
        return result.invite_link
    except Exception as e:
        logger.warning(f"[invite] Не удалось создать ссылку для {uid}: {e}")
        return GROUP_LINK

