async def main():
    if BOT_TOKEN == "YOUR_BOT_TOKEN_HERE":
        logger.critical("❌ Укажи BOT_TOKEN в конфиге!")
        return
    if ADMIN_IDS == [123456789]:
        logger.warning("⚠️  ADMIN_IDS содержит заглушку — укажи свой Telegram ID!")
    if LOG_GROUP_ID == -1001234567890:
        logger.warning("⚠️  LOG_GROUP_ID не задан — логи выплат не будут отправляться!")

    await init_db()
    logger.info("✅ База данных инициализирована")

    bot = Bot(
        token=BOT_TOKEN,
        default=DefaultBotProperties(parse_mode="HTML")
    )

    try:
        me = await bot.get_me()
        logger.info(f"✅ Бот запущен: @{me.username}  (id={me.id})")
    except Exception as e:
        logger.critical(f"❌ Ошибка подключения к Telegram: {e}")
        await bot.session.close()
        return

    dp = Dispatcher(storage=MemoryStorage())
    dp.include_router(router)

    try:
        await bot.delete_webhook(drop_pending_updates=True)
        logger.info("✅ Вебхук удалён, запускаем long polling")
    except Exception as e:
        logger.warning(f"Не удалось удалить вебхук: {e}")

    try:
        await dp.start_polling(
            bot,
            skip_updates=True,
            allowed_updates=dp.resolve_used_update_types(),
            close_bot_session=True,
        )
    finally:
        await bot.session.close()
        logger.info("🛑 Бот остановлен")


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except (KeyboardInterrupt, SystemExit):
        logger.info("🛑 Остановлен вручную")
