            logger.error(f"Ошибка отправки заявки админу {adm}: {e}")

    await cb.message.edit_text(
        f'{E["check"]} <b>Заявка #{pid} отправлена!</b>\n\n'
        f'{E["timer"]} Администратор рассмотрит её в ближайшее время.\n'
