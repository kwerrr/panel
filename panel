        f'🖼 NFT ссылки:\n{d["nft"]}\n\n'
        f'⚙️ Комиссия: {comm}%'
    )
    for adm in ADMIN_IDS:
        try:
            screens = d.get("screens", [])
            if screens:
                if len(screens) == 1:
                    await bot.send_photo(adm, screens[0], caption="📸 Скриншоты сделки")
