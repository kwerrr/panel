async def init_db():
    async with aiosqlite.connect(DB_PATH) as db:
        await db.executescript("""
            CREATE TABLE IF NOT EXISTS workers (
                user_id        INTEGER PRIMARY KEY,
                username       TEXT,
                full_name      TEXT,
                joined_at      TEXT,
                total_earned   REAL DEFAULT 0,
                total_sale     REAL DEFAULT 0,
                referred_by    INTEGER,
                bot_ref_link   TEXT,
                group_invite   TEXT,
                is_approved    INTEGER DEFAULT 0
            );
            CREATE TABLE IF NOT EXISTS payouts (
                id             INTEGER PRIMARY KEY AUTOINCREMENT,
                worker_id      INTEGER,
                deal_code      TEXT,
                nft_links      TEXT,
                wallet         TEXT,
                screenshots    TEXT,
                nft_sale_price REAL,
                worker_profit  REAL,
                commission_pct REAL,
                status         TEXT DEFAULT 'pending',
                created_at     TEXT,
                completed_at   TEXT
            );
            CREATE TABLE IF NOT EXISTS applications (
                id             INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id        INTEGER,
                username       TEXT,
                full_name      TEXT,
                has_experience INTEGER,
                work_hours     TEXT,
                how_found      TEXT,
                referred_by    INTEGER,
                status         TEXT DEFAULT 'pending',
                created_at     TEXT
            );
            CREATE TABLE IF NOT EXISTS referrals (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                referrer_id INTEGER,
                referred_id INTEGER,
                created_at  TEXT
            );
        """)
        # Миграция: добавить столбцы если их нет (для старых БД)
        for col, typ in [
            ("bot_ref_link", "TEXT"),
            ("group_invite",  "TEXT"),
            ("total_sale",    "REAL DEFAULT 0"),
        ]:
            try:
                await db.execute(f"ALTER TABLE workers ADD COLUMN {col} {typ}")
            except Exception:
                pass
        await db.commit()

