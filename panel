@router.callback_query(F.data.startswith("confirm_pay_"))
async def confirm_pay(cb: CallbackQuery, bot: Bot):
    if not is_admin(cb.from_user.id):
        await cb.answer("❌ Нет прав.", show_alert=True); return

    pid = int(cb.data.split("_")[-1])
    p   = await db_get_payout(pid)
    if not p:
        await cb.answer("Заявка не найдена.", show_alert=True); return
    if p["status"] == "completed":
        await cb.answer("Уже выплачено.", show_alert=True); return

    # FIX: проверяем что цена была выставлена перед подтверждением
    if not p["nft_sale_price"]:
        await cb.answer("⚠️ Сначала укажи сумму продажи!", show_alert=True); return

    await db_complete_payout(pid)
    await db_add_profit(p["worker_id"], p["worker_profit"], p["nft_sale_price"])

    w    = await db_get_worker(p["worker_id"])
    wnam = w["full_name"] if w else f"ID:{p['worker_id']}"
    wun  = f" @{w['username']}" if w and w["username"] else ""

    await safe_send(bot, p["worker_id"],
        text=(
            f'{E["star"]} <b>Выплата произведена!</b>\n\n'
            f'🔖 Сделка: <code>{p["deal_code"]}</code>\n'
            f'{E["coin"]} Сумма: <b>{p["worker_profit"]:.4f} TON</b>\n'
            f'{E["card"]} На кошелёк: <code>{p["wallet"]}</code>'
        )
    )

    commission_amount = round(p["nft_sale_price"] * p["commission_pct"] / 100, 6)
    log_text = (
        f'{E["check"]} <b>Успешная выплата #{pid}</b>\n\n'
        f'👤 {wnam}{wun}  (<code>{p["worker_id"]}</code>)\n'
        f'🔖 Сделка: <code>{p["deal_code"]}</code>\n\n'
        f'{E["dollar"]} Продано:              <b>{p["nft_sale_price"]:.4f} TON</b>\n'
        f'{E["warn"]} Комиссия ({p["commission_pct"]}%): <b>{commission_amount:.4f} TON</b>\n'
        f'{E["coin"]} Выплачено воркеру:  <b>{p["worker_profit"]:.4f} TON</b>\n\n'
        f'{E["card"]} Кошелёк: <code>{p["wallet"]}</code>'
    )
    try:
        await bot.send_message(chat_id=LOG_GROUP_ID, text=log_text)
        logger.info(f"[LOG] Выплата #{pid} → {LOG_GROUP_ID}")
    except Exception as e:
        logger.error(f"[LOG] Не удалось отправить лог #{pid} в {LOG_GROUP_ID}: {e}")

    await cb.message.edit_text(
        f'{E["check"]} <b>Выплата #{pid} подтверждена!</b>\n\n'
        f'{wnam} получил <b>{p["worker_profit"]:.4f} TON</b>\n'
        f'{E["mega"]} Лог отправлен в группу.'
    )
    await cb.answer()

