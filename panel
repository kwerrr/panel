@router.callback_query(F.data.startswith("app_accept_"))
async def app_accept(cb: CallbackQuery, bot: Bot):
    if not is_admin(cb.from_user.id):
        await cb.answer("❌ Нет прав.", show_alert=True)
        return

    aid = int(cb.data.split("_")[-1])
    app = await db_get_app(aid)
    if not app:
        await cb.answer("Заявка не найдена.", show_alert=True); return
    if app["status"] != "pending":
        await cb.answer("Уже обработана.", show_alert=True); return

    # FIX: сначала обновляем статус (защита от двойного нажатия)
    await db_update_app(aid, "accepted")
    await db_add_worker(app["user_id"], app["username"], app["full_name"], app["referred_by"])

    if app["referred_by"]:
        await db_add_referral(app["referred_by"], app["user_id"])

    traffer_id    = app["referred_by"]
    group_for_new = GROUP_LINK

    if traffer_id:
        traffer = await db_get_worker(traffer_id)
        if traffer and traffer["group_invite"]:
            group_for_new = traffer["group_invite"]
        else:
            tname = traffer["full_name"] if traffer else f"id{traffer_id}"
            new_g = await make_group_invite(bot, traffer_id, tname)
            tbot  = f"https://t.me/{BOT_USERNAME}?start=ref_{traffer_id}"
            await db_save_links(traffer_id, tbot, new_g)
            group_for_new = new_g

    new_bot = f"https://t.me/{BOT_USERNAME}?start=ref_{app['user_id']}"
    new_grp = await make_group_invite(bot, app["user_id"], app["full_name"])
    await db_save_links(app["user_id"], new_bot, new_grp)

    await safe_send(bot, app["user_id"],
        text=(
            f'{E["check"]} <b>Заявка принята! Добро пожаловать в команду!</b>\n\n'
            f'{E["globe"]} Ссылка на группу:\n<code>{group_for_new}</code>\n\n'
            f'{E["down"]} Нажми /start чтобы открыть панель.'
        )
    )

    if traffer_id:
        tdisp = app["full_name"] + (f' (@{app["username"]})' if app["username"] else "")
        await safe_send(bot, traffer_id,
            text=(
                f'{E["star"]} <b>Твой реферал принят в команду!</b>\n\n'
                f'👤 {tdisp}\n'
                f'{E["handshake"]} Теперь он в твоей команде.'
            )
        )

    un = f"@{app['username']}" if app["username"] else app["full_name"]
    await cb.message.edit_text(
        f'{E["check"]} Заявка #{aid} от <b>{un}</b> — ПРИНЯТА\n'
        f'Воркер получил персональную ссылку на группу.'
    )
    await cb.answer()

