async def init_db():
    async with aiosqlite.connect(DB_PATH) as db:
        await db.executescript("""
            CREATE TABLE IF NOT EXISTS workers (
                user_id        INTEGER PRIMARY KEY,
                username       TEXT,
                full_name      TEXT,
                joined_at      TEXT,
                total_earned   REAL DEFAULT 0,
                total_sale     REAL DEFAULT 0,
                referred_by    INTEGER,
                bot_ref_link   TEXT,
                group_invite   TEXT,
                is_approved    INTEGER DEFAULT 0
            );
            CREATE TABLE IF NOT EXISTS payouts (
                id             INTEGER PRIMARY KEY AUTOINCREMENT,
                worker_id      INTEGER,
                deal_code      TEXT,
                nft_links      TEXT,
                wallet         TEXT,
                screenshots    TEXT,
                nft_sale_price REAL,
                worker_profit  REAL,
                commission_pct REAL,
                status         TEXT DEFAULT 'pending',
                created_at     TEXT,
                completed_at   TEXT
            );
            CREATE TABLE IF NOT EXISTS applications (
                id             INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id        INTEGER,
                username       TEXT,
                full_name      TEXT,
                has_experience INTEGER,
                work_hours     TEXT,
                how_found      TEXT,
                referred_by    INTEGER,
                status         TEXT DEFAULT 'pending',
                created_at     TEXT
            );
            CREATE TABLE IF NOT EXISTS referrals (
                id          INTEGER PRIMARY KEY AUTOINCREMENT,
                referrer_id INTEGER,
                referred_id INTEGER,
                created_at  TEXT
            );
            CREATE TABLE IF NOT EXISTS config (
                key   TEXT PRIMARY KEY,
                value TEXT
            );
        """)
        # Миграция для старых баз
        for col, typ in [
            ("bot_ref_link", "TEXT"),
            ("group_invite",  "TEXT"),
            ("total_sale",    "REAL DEFAULT 0"),
        ]:
            try:
                await db.execute(f"ALTER TABLE workers ADD COLUMN {col} {typ}")
            except Exception:
                pass
        # Инициализировать комиссию по умолчанию если не задана
        await db.execute(
            "INSERT OR IGNORE INTO config (key, value) VALUES ('commission_pct', ?)",
            (str(DEFAULT_COMMISSION_PCT),)
        )
        await db.commit()

# ── Config (комиссия в БД) ────────────────────────────────

async def db_get_commission() -> int:
    async with aiosqlite.connect(DB_PATH) as db:
        async with db.execute("SELECT value FROM config WHERE key='commission_pct'") as c:
            r = await c.fetchone()
            return int(r[0]) if r else DEFAULT_COMMISSION_PCT

async def db_set_commission(pct: int):
    async with aiosqlite.connect(DB_PATH) as db:
        await db.execute(
            "INSERT OR REPLACE INTO config (key, value) VALUES ('commission_pct', ?)",
            (str(pct),)
        )
        await db.commit()

