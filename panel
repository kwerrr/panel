@router.message(Command("setcommission"))
async def admin_setcomm(msg: Message):
    global COMMISSION_PCT
    if not is_admin(msg.from_user.id): return
    parts = msg.text.split()
    if len(parts) < 2:
        await msg.answer(
            f'{E["bulb"]} Текущая комиссия: <b>{COMMISSION_PCT}%</b>\n\n'
            f'Использование: /setcommission 30', parse_mode="HTML"
        )
        return
    try:
        v = int(parts[1])
        assert 0 <= v <= 100
    except (ValueError, AssertionError):
        await msg.answer(f'{E["warn"]} Введи число от 0 до 100', parse_mode="HTML")
        return
    COMMISSION_PCT = v
    await msg.answer(
        f'{E["check"]} Комиссия изменена на <b>{v}%</b>\n'
        f'<i>Применится к новым заявкам.</i>', parse_mode="HTML"
    )

