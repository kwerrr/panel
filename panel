@router.message(CommandStart())
async def cmd_start(msg: Message, state: FSMContext):
    await state.clear()   # FIX: сбрасываем любое висящее состояние
    uid  = msg.from_user.id
    args = msg.text.split()
    ref  = None
    if len(args) > 1 and args[1].startswith("ref_"):
        try:
            ref = int(args[1][4:])
            if ref == uid:      # FIX: нельзя рефералить самого себя
                ref = None
        except ValueError:
            pass

    worker = await db_get_worker(uid)
    if worker and worker["is_approved"]:
